<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ahmad Logo Designer</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            background:#000;
            color:#fff;
            text-align:center;
        }

        header{
            padding:30px;
            background:#111;
        }

        h1{
            font-size:40px;
        }

        p{
            color:#ccc;
            margin-top:10px;
        }

        .gallery{
            padding:50px 20px;
        }

        .gallery img{
            width:90%;
            max-width:1200px;
            border:3px solid white;
            border-radius:12px;
            box-shadow:0 0 20px rgba(255,255,255,.2);
        }

        footer{
            padding:20px;
            background:#111;
            margin-top:40px;
        }
    </style>
</head>
<body>

<header>
    <h1>Ahmad Logo Designer</h1>
    <p>Professional Logo Portfolio</p>
</header>

<section class="gallery">
    <img src="images/logos.jpg" alt="Logo Portfolio">
</section>

<footer>
    <p>WhatsApp: 03019621779</p>
    <p>Email: ansajee10@gmail.com</p>
    <p>© 2026 Ahmad Logo Designer</p>
</footer>

</body>
</html>
